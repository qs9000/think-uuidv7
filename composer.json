{
    "name": "qs9000/think-uuidv7",
    "description": "ThinkPHP8 Redis-based UUIDv7 Generator for Distributed Systems",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": [
        "uuid",
        "uuidv7",
        "distributed",
        "thinkphp",
        "id-generator",
        "unique-id"
    ],
    "authors": [
        {
            "name": "qs9000",
            "email": "pengshuiqing@163.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "topthink/framework": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "qs9000\\thinkuuidv7\\": "src/"
        }
    },
    "extra": {
        "think": {
            "config": {
                "uuidv7": "src/config/uuidv7.php"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    }
}